# Batch Connect app configuration file  (ERB-rendered)
#
# The RStudio image list is DISCOVERED, not hard-coded. Whatever
# sync-images.sh has placed in the image directory shows up here, labelled with
# the R / RStudio versions read out of that image at pull time (images.json).
#
# Consequences worth knowing:
#   * Adding an R version upstream requires no edit to this file. Run
#     `sync-images.sh --sync` and it appears in the dropdown.
#   * A version is only offered if its per-user package library exists. This is
#     what stops the app from handing you an R_LIBS_USER that points nowhere --
#     R ignores a missing library path silently, so the failure was invisible.
#   * There is no separate "R packages" dropdown any more. The library is a
#     function of the image (packages built for one R minor will not load under
#     another), so script.sh.erb derives it from the chosen image instead of
#     letting the two be set independently.
#
# The image directory is the shared artifact. R_LIBS_ROOT is per-user: someone
# reusing this app must point it at their own library root.
---
<%-
  require 'json'

  # Config written by install.sh. This is read from a file rather than the
  # environment because OnDemand renders this template inside the PUN, which
  # does not reliably source your shell rc. Environment still wins if set.
  rsd_conf = lambda do
    path = ENV['RSTUDIO_DEV_CONFIG'] || File.join(Dir.home, '.config', 'rstudio_dev', 'config')
    conf = {}
    if File.readable?(path)
      File.readlines(path).each do |line|
        line = line.strip
        next if line.empty? || line.start_with?('#')
        k, v = line.split('=', 2)
        conf[k.strip] = v.strip if k && v
      end
    end
    conf
  end.call

  setting = lambda { |key, default| ENV[key] || rsd_conf[key] || default }

  image_dir   = setting.call('RSTUDIO_IMAGE_DIR', "#{Dir.home}/work/images/rstudio")
  r_libs_root = setting.call('R_LIBS_ROOT',       "#{Dir.home}/work/R/x86_64-pc-linux-gnu-library")
  cluster     = setting.call('RSTUDIO_CLUSTER',   'iris')
  queue       = setting.call('RSTUDIO_QUEUE',     'cpu')

  # Partitions offered in the Queue dropdown. `RSTUDIO_QUEUES` is a
  # comma-separated list; if unset, fall back to the single `queue` value so a
  # fresh install behaves exactly as before. GPU partitions are site-specific
  # (e.g. this cluster denies `shahs3` on the shared `gpu` partition but allows
  # `componc_gpu_batch`), which is precisely why they come from config, not code.
  #
  # Each entry is `partition` or `partition|Human readable label`. install.sh
  # generates the labels from Slurm (GPU types, max wall time), so the dropdown
  # shows e.g. "componc_gpu_int — GPU: H100/H200 · <=1d · interactive". The
  # submitted value is always the bare partition (before the `|`).
  queue_opts = setting.call('RSTUDIO_QUEUES', queue)
                      .split(',').map(&:strip).reject(&:empty?)
                      .map do |entry|
    value, label = entry.split('|', 2)
    value = value.to_s.strip
    label = (label && !label.strip.empty?) ? label.strip : value
    [label, value]
  end
  queue_opts = [[queue, queue]] if queue_opts.empty?

  info = {}
  manifest = File.join(image_dir, 'images.json')
  if File.readable?(manifest)
    begin
      JSON.parse(File.read(manifest)).each { |e| info[e['r_version']] = e }
    rescue JSON::ParserError
      info = {}
    end
  end

  # rstudio-<minor>.sif only. Legacy tag-named images (rstudio-v2.0.sif) are
  # deliberately not matched: their filename does not state which R they carry.
  versions = Dir.glob(File.join(image_dir, 'rstudio-*.sif'))
                .map  { |p| File.basename(p)[/\Arstudio-(\d+\.\d+)\.sif\z/, 1] }
                .compact
                .select { |v| Dir.exist?(File.join(r_libs_root, "#{v}_singularity")) }
                .sort_by { |v| v.split('.').map(&:to_i) }
                .reverse

  label_for = lambda do |v|
    i = info[v]
    next "R #{v}" unless i
    bits = ["R #{i['r_full'] || v}"]
    bits << "RStudio #{i['rstudio']}" if i['rstudio'] && i['rstudio'] != 'unknown'
    bits.join(' · ')
  end

  # Named session "slots". Each slot has its own XDG_DATA_HOME/XDG_CACHE_HOME
  # (script.sh.erb), so multiple sessions with different names run concurrently
  # without colliding, and each slot's RStudio state persists across relaunches.
  # Discover existing slots here so the form can offer them for resume, newest
  # first, with a last-used hint from the directory mtime.
  slots_root = File.join(Dir.home, 'work', '.rstudio-sessions')
  ago = lambda do |t|
    s = Time.now - t
    next 'just now'          if s < 60
    next "#{(s/60).to_i}m ago"   if s < 3600
    next "#{(s/3600).to_i}h ago" if s < 86400
    "#{(s/86400).to_i}d ago"
  end
  slot_opts = Dir.glob(File.join(slots_root, '*'))
                 .select { |p| File.directory?(p) }
                 .sort_by { |p| -File.mtime(p).to_i }
                 .map { |p| ["#{File.basename(p)}  (last used #{ago.call(File.mtime(p))})", File.basename(p)] }
  # Always offer "default", listed first if it is not already present.
  slot_opts.unshift(['default', 'default']) unless slot_opts.any? { |_, v| v == 'default' }
-%>

cluster: "<%= cluster %>"

attributes:
  modules: ""
  extra_rstudio_args: ""

  session_name:
    widget: "select"
    label: "Session"
    help: "Resume a previous session, or pick 'default'. To start a fresh named session, type a name in 'New session name' below (it overrides this)."
    options:
<%- slot_opts.each do |label, value| -%>
      - [ "<%= label %>", "<%= value %>" ]
<%- end -%>
  new_session_name:
    widget: "text_field"
    label: "New session name (optional)"
    value: ""
    help: "Give a fresh session its own name — its state persists and can be resumed later. Leave blank to use the Session picked above. Letters, digits, . _ - only."

  queue:
    widget: "select"
    label: "Queue"
    value: "<%= queue %>"
    help: "Pick a GPU partition (and set GPUs > 0) to get a GPU."
    options:
<%- queue_opts.each do |label, value| -%>
      - [ "<%= label %>", "<%= value %>" ]
<%- end -%>
  num_cores:
    widget: "number_field"
    label: "Number of cores"
    value: 8
    help: "Maximum number of CPU cores is 72"
    min: 1
    step: 1
  num_gpus:
    widget: "number_field"
    label: "Number of GPUs"
    value: 0
    min: 0
    step: 1
    help: "Requires a GPU partition above. 0 = CPU-only. Each GPU also grants 1 core by default."
  num_hours:
    widget: "number_field"
    label: "Number of hours"
    value: 8
    min: 1
    step: 1
    help: "Time in hours"
  memory:
    widget: "number_field"
    label: "Memory"
    value: 8
    min: 8
    step: 1

  rstudio_image:
    widget: "select"
    label: "RStudio image"
<%- if versions.empty? -%>
    help: "NO IMAGES FOUND in <%= image_dir %> with a matching package library in <%= r_libs_root %>. Run sync-images.sh --sync"
    options:
      - [ "none available", "" ]
<%- else -%>
    help: "R package library is selected automatically to match. Run sync-images.sh to update this list."
    options:
<%- versions.each do |v| -%>
      - [ "<%= label_for.call(v) %>", "<%= File.join(image_dir, "rstudio-#{v}.sif") %>" ]
<%- end -%>
<%- end -%>

form:
  - modules
  - session_name
  - new_session_name
  - queue
  - num_cores
  - num_gpus
  - num_hours
  - memory
  - rstudio_image
