#!/usr/bin/env bash
<%-
  # The package library is a function of the image, not an independent choice:
  # packages built for one R minor version will not load under another. Deriving
  # it here removes the old parallel `r_packages` dropdown, which could be set to
  # a library that did not match -- or, as with R 4.4, did not exist at all.
  image   = File.realpath(context.rstudio_image)
  r_minor = File.basename(image)[/(\d+\.\d+)/, 1]
  raise "cannot determine R version from image #{image}" if r_minor.nil?

  # Named session slot. `new_session_name` (a fresh name typed by the user) wins
  # over the `session_name` picked from the resume dropdown; else "default".
  # Sanitised hard because it becomes a path component: keep only safe chars, and
  # never allow empty or "." / "..".
  raw_slot = (context.respond_to?(:new_session_name) ? context.new_session_name.to_s : '')
  raw_slot = context.session_name.to_s if raw_slot.strip.empty? && context.respond_to?(:session_name)
  # One path segment (no slashes survive), leading dots stripped so it is never a
  # dotfile or "." / ".." -- so it cannot traverse out of ~/work/.rstudio-sessions.
  slot = raw_slot.strip.gsub(/[^A-Za-z0-9._-]/, '_').sub(/\A\.+/, '')
  slot = 'default' if slot.empty?

  # Same config file the form reads (written by install.sh); env wins if set.
  rsd_conf = lambda do
    path = ENV['RSTUDIO_DEV_CONFIG'] || File.join(Dir.home, '.config', 'rstudio_dev', 'config')
    conf = {}
    if File.readable?(path)
      File.readlines(path).each do |line|
        line = line.strip
        next if line.empty? || line.start_with?('#')
        k, v = line.split('=', 2)
        conf[k.strip] = v.strip if k && v
      end
    end
    conf
  end.call

  r_libs_root = ENV['R_LIBS_ROOT'] || rsd_conf['R_LIBS_ROOT'] ||
                "#{Dir.home}/work/R/x86_64-pc-linux-gnu-library"
  r_libs      = File.join(r_libs_root, "#{r_minor}_singularity")
-%>

# Load the required environment
setup_env () {
  module purge
}
setup_env

#
# Start RStudio Server
#

# Package library for R <%= r_minor %>, derived from the selected image.
# R silently ignores a missing R_LIBS_USER, so fail loudly instead.
export R_LIBS_USER="<%= r_libs %>"
if [[ ! -d "${R_LIBS_USER}" ]]; then
  echo "R package library not found: ${R_LIBS_USER}" >&2
  echo "Create it with: mkdir -p '${R_LIBS_USER}'" >&2
  exit 1
fi

# PAM auth helper used by RStudio
export RSTUDIO_AUTH="${PWD}/bin/auth"

# ---- GPU passthrough decision -------------------------------------------------
# Computed here (before the rsession wrapper is written) so the chosen CUDA build
# can be exported into the R session.
#
# Enable --nv only when Slurm actually GRANTED a GPU, signalled via
# CUDA_VISIBLE_DEVICES / SLURM_JOB_GPUS (set by the gres plugin). Do NOT probe
# /dev/nvidia*: a CPU job that lands on a GPU-capable node (GPU nodes are in CPU
# partitions too) sees those device files despite being granted no GPU, so
# probing them would enable --nv for a CPU session and let it grab a GPU
# allocated to another user. --nv binds only the host driver (libcuda.so).
NV_FLAG=""
TORCH_CUDA_EXPORT=""
if [ -n "${CUDA_VISIBLE_DEVICES:-}" ] || [ -n "${SLURM_JOB_GPUS:-}" ] || [ -n "${GPU_DEVICE_ORDINAL:-}" ]; then
  NV_FLAG="--nv"
  echo "GPU granted (CUDA_VISIBLE_DEVICES='${CUDA_VISIBLE_DEVICES:-}', SLURM_JOB_GPUS='${SLURM_JOB_GPUS:-}') -> enabling Singularity --nv"

  # Pick the R torch CUDA build for THIS node, rather than hardcoding one: the
  # highest torch-supported build that does not exceed the driver's max CUDA
  # (from nvidia-smi). Read live per node, so it adapts to per-node drivers and
  # future upgrades. The image ships no CUDA toolkit, so torch's auto-installer
  # would otherwise fetch the CPU build; exporting CUDA into the R session makes
  # torch::install_torch() fetch the matching GPU build (only the driver is
  # needed at runtime -- the build bundles the toolkit). The supported list is
  # config-overridable (RSTUDIO_TORCH_CUDA) so new cuXXX builds need no code edit.
  _torch_cuda_supported="<%= (rsd_conf['RSTUDIO_TORCH_CUDA'] || '12.9 12.8 12.6') %>"
  _cuda_ceiling="$(nvidia-smi 2>/dev/null | grep -oE 'CUDA Version: [0-9]+\.[0-9]+' | grep -oE '[0-9]+\.[0-9]+' | head -1)"
  if [ -n "${_cuda_ceiling}" ]; then
    for _b in ${_torch_cuda_supported}; do
      if [ "$(printf '%s\n%s\n' "${_b}" "${_cuda_ceiling}" | sort -V | tail -1)" = "${_cuda_ceiling}" ]; then
        TORCH_CUDA_EXPORT="export CUDA=\"${_b}\""
        echo "R torch -> CUDA ${_b} (node driver supports up to ${_cuda_ceiling})"
        break
      fi
    done
    [ -n "${TORCH_CUDA_EXPORT}" ] || echo "No torch CUDA build <= driver ${_cuda_ceiling}; leaving CUDA unset (torch will choose)"
  fi
else
  echo "No GPU granted to this job -> CPU-only (no --nv)"
fi
# ------------------------------------------------------------------------------

# Named session slot. Each slot gets its own XDG_DATA_HOME (RStudio session and
# workspace state), so multiple sessions run concurrently without stepping on
# each other's session registry. XDG_CACHE_HOME and XDG_CONFIG_HOME stay shared
# (renv library + preferences). Slots live under ~/work (a symlink to /data1),
# NOT $HOME proper, which is small -- so slot state does not consume the home
# quota. The slot dir persists, so a slot resumes and shows in the Session
# dropdown.
SESSION_SLOT="<%= slot %>"
SLOT_DIR="${HOME}/work/.rstudio-sessions/${SESSION_SLOT}"
mkdir -p "${SLOT_DIR}/data" "${HOME}/work/.cache"
echo "RStudio session slot: ${SESSION_SLOT}  (state in ${SLOT_DIR}/data; cache + renv shared)"

# Generate an `rsession` wrapper script
export RSESSION_WRAPPER_FILE="${PWD}/rsession.sh"
(
umask 077
sed 's/^ \{2\}//' > "${RSESSION_WRAPPER_FILE}" << EOL
  #!/usr/bin/env bash

  echo 'slurm:x:300:300::/opt/slurm/slurm:/bin/false' >> /etc/passwd
  # We fix the path and remove all the junk I had
  export PATH=/usr/lib/rstudio-server/bin/:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin:$HOME/.local/host/bin:$PATH

  # Per-slot RStudio session/workspace state lives under XDG_DATA_HOME, so
  # isolating it is what lets concurrent sessions coexist.
  export XDG_DATA_HOME="${SLOT_DIR}/data"
  # XDG_CACHE_HOME stays SHARED. renv stores its package library and cache under
  # R_user_dir("renv","cache") == \$XDG_CACHE_HOME/R/renv -- so a per-slot cache
  # moves every renv project's library out from under it (.libPaths breaks).
  # XDG_CONFIG_HOME is likewise left at ~/.config so preferences stay shared.
  export XDG_CACHE_HOME="${HOME}/work/.cache/"

  # torch: on a GPU job, use the CUDA build matching this node's driver (chosen
  # above). Empty on CPU jobs, so this line vanishes and torch stays CPU.
  ${TORCH_CUDA_EXPORT}

  # Log all output from this script
  export RSESSION_LOG_FILE="${PWD}/rsession.log"

  exec &>>"\${RSESSION_LOG_FILE}"

  # Launch the original command
  echo "Launching rsession..."
  set -x
  exec rsession --r-libs-user "${R_LIBS_USER}" "\${@}"
EOL
)
chmod 700 "${RSESSION_WRAPPER_FILE}"

# Set working directory to home directory
cd "${HOME}"

# Output debug info
# module list

# echo old TMPDIR $TMPDIR
export TMPDIR=`mktemp -d`
# echo new TMPDIR $TMPDIR

mkdir -p $TMPDIR/{run,var-lib-rstudio-server,local-share-rstudio,usr}

# RStudio Server 2026.06+ treats an unreadable /etc/rstudio/database.conf as a
# fatal error; 2025.09 tolerated it. The rstudio-server deb ships that file
# 0600 root:root, which is fine under Docker (where you are root) but unreadable
# under Singularity, where you are not. Point rserver at our own copy. Older
# RStudio accepts the same flag, so this is safe across all images.
cat > "${TMPDIR}/database.conf" <<'DBCONF'
provider=sqlite
directory=/var/lib/rstudio-server
DBCONF
chmod 600 "${TMPDIR}/database.conf"

# rocker's install_rstudio.sh sets logger-type=syslog, and there is no syslog in
# the container -- so rserver startup failures vanish silently and the only
# symptom is `wait_until_port_used` timing out. Log to stderr so they land in
# this job's output.log instead.
cat > "${TMPDIR}/logging.conf" <<'LOGCONF'
[*]
log-level=warn
logger-type=stderr
LOGCONF

# Clear the "session did not exit cleanly" prompt for THIS slot only. Scoped to
# the slot's own XDG_DATA_HOME (was ${HOME}/work/.rstudio, which is shared -- so
# launching one session used to reset every other running session's abend flag).
# RStudio keeps session state under $XDG_DATA_HOME/rstudio.
RSTUDIO_STATE_DIR="${RSTUDIO_STATE_DIR:-${SLOT_DIR}/data/rstudio}"
shopt -s nullglob
for state in "${RSTUDIO_STATE_DIR}"/sessions/active/*/session-persistent-state; do
  sed -i -e 's/abend="1"/abend="0"/' "${state}"
done
shopt -u nullglob

set -x
# Launch the RStudio Server
echo "Starting up rserver..."

export RSTUDIO_USER="${USER}"

# NV_FLAG and the torch CUDA build were decided earlier (before the rsession
# wrapper was written, so the CUDA choice could be exported into the R session).

# Singularity forwards the host environment into the container, and this host
# exports SSL_CERT_FILE=/etc/pki/... and SSL_CERT_DIR=/etc/pki/... -- RHEL paths
# that do not exist inside the Ubuntu image. Anything doing TLS with OpenSSL
# then fails; Quarto (Deno) dies with "Failed to load platform certificates".
# Point them at the container's own CA bundle rather than using --cleanenv,
# which would also strip SLURM_* and the RStudio variables we rely on.
singularity exec ${NV_FLAG} -B "$TMPDIR:/tmp" \
 -B "$TMPDIR/run:/run" \
 -B "$TMPDIR/var-lib-rstudio-server:/var/lib/rstudio-server" \
 -B "$TMPDIR/local-share-rstudio:/home/rstudio/.local/share/rstudio" \
 -B "$TMPDIR/logging.conf:/etc/rstudio/logging.conf" \
 -B "/data1:/data1" \
 -B "/run/munge/,/etc/slurm/,/usr/lib64/slurm,/usr/lib64/libmunge.so.2" \
 -B "${HOME}:${HOME}" \
 --env SSL_CERT_FILE=/etc/ssl/certs/ca-certificates.crt \
 --env SSL_CERT_DIR=/etc/ssl/certs \
 "<%= image %>" rserver \
 --database-config-file=/tmp/database.conf \
 --server-user="${RSTUDIO_USER}" \
 --www-port="${port}" \
 --auth-none=0 \
 --auth-pam-require-password-prompt=0 \
 --auth-pam-helper-path="${RSTUDIO_AUTH}" \
 --auth-encrypt-password=0 \
 --auth-timeout-minutes=6000 \
 --rsession-path="${RSESSION_WRAPPER_FILE}"

# note, rserver in the container will start with the user space environment defined on host
# BUT, the rsession starts on limited environment, only related to R = no SLURM*, http*, ...
# so anything we want to pass to rsession needs to be set in $RSESSION_WRAPPER_FILE
