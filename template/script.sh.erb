#!/usr/bin/env bash
<%-
  # The form's "none available" placeholder submits an empty value, and a user
  # CAN click Launch on it. File.realpath("") raises a bare Errno::ENOENT with a
  # ruby backtrace; say what is actually wrong instead.
  raise 'No RStudio image was selected -- the form found no images with a ' \
        'matching package library. Run sync-images.sh --sync and relaunch.' \
    if context.rstudio_image.to_s.strip.empty?

  # The package library is a function of the image, not an independent choice:
  # packages built for one R minor version will not load under another. Deriving
  # it here removes the old parallel `r_packages` dropdown, which could be set to
  # a library that did not match -- or, as with R 4.4, did not exist at all.
  image   = File.realpath(context.rstudio_image)
  r_minor = File.basename(image)[/(\d+\.\d+)/, 1]
  raise "cannot determine R version from image #{image}" if r_minor.nil?

  # Named session slot. `new_session_name` (a fresh name typed by the user) wins
  # over the `session_name` picked from the resume dropdown; else "default".
  # Sanitised hard because it becomes a path component: keep only safe chars, and
  # never allow empty or "." / "..".
  raw_slot = (context.respond_to?(:new_session_name) ? context.new_session_name.to_s : '')
  raw_slot = context.session_name.to_s if raw_slot.strip.empty? && context.respond_to?(:session_name)
  # One path segment (no slashes survive), leading dots stripped so it is never a
  # dotfile or "." / ".." -- so it cannot traverse out of ~/work/.rstudio-sessions.
  slot = raw_slot.strip.gsub(/[^A-Za-z0-9._-]/, '_').sub(/\A\.+/, '')
  slot = 'default' if slot.empty?

  # Same config file the form reads (written by install.sh); env wins if set.
  rsd_conf = lambda do
    path = ENV['RSTUDIO_DEV_CONFIG'] || File.join(Dir.home, '.config', 'rstudio_dev', 'config')
    conf = {}
    if File.readable?(path)
      File.readlines(path).each do |line|
        line = line.strip
        next if line.empty? || line.start_with?('#')
        k, v = line.split('=', 2)
        conf[k.strip] = v.strip if k && v
      end
    end
    conf
  end.call

  setting = lambda { |key, default| ENV[key] || rsd_conf[key] || default }

  r_libs_root = setting.call('R_LIBS_ROOT', "#{Dir.home}/work/R/x86_64-pc-linux-gnu-library")
  r_libs      = File.join(r_libs_root, "#{r_minor}_singularity")

  # Session state and caches live under RSTUDIO_WORK_DIR, chosen at install time.
  # The default reproduces the old hard-coded ~/work, so an install that predates
  # the key keeps its existing slots.
  work_dir    = setting.call('RSTUDIO_WORK_DIR', "#{Dir.home}/work")

  # Host paths bound into the container beyond $HOME. Site-specific (this cluster
  # has /data1; another will not), so they are configured rather than hard-coded.
  # Emitted as a bash list and filtered against what exists on the compute node --
  # singularity fails outright on a bind source that is not there.
  singularity = setting.call('RSTUDIO_SINGULARITY', 'singularity')
  # Fallback to the installer's default app dir: installs whose config predates
  # RSTUDIO_APP_DIR would otherwise never see an update notice.
  app_dir     = setting.call('RSTUDIO_APP_DIR', "#{Dir.home}/ondemand/dev/rstudio_dev")
  bind_paths  = setting.call('RSTUDIO_BIND_PATHS',
                             '/data1,/run/munge,/etc/slurm,/usr/lib64/slurm,/usr/lib64/libmunge.so.2')
                  .split(',').map(&:strip).reject(&:empty?)
-%>

# Load the required environment
setup_env () {
  # Guarded: `module` is a shell function OnDemand exports when the site has
  # environment modules; a site without them must not die on the first line.
  if command -v module >/dev/null 2>&1; then module purge; fi
}
setup_env

#
# Start RStudio Server
#

# Package library for R <%= r_minor %>, derived from the selected image.
# R silently ignores a missing R_LIBS_USER, so fail loudly instead.
export R_LIBS_USER="<%= r_libs %>"
if [[ ! -d "${R_LIBS_USER}" ]]; then
  echo "R package library not found: ${R_LIBS_USER}" >&2
  echo "Create it with: mkdir -p '${R_LIBS_USER}'" >&2
  exit 1
fi

# PAM auth helper used by RStudio
export RSTUDIO_AUTH="${PWD}/bin/auth"

# ---- GPU passthrough decision -------------------------------------------------
# Computed here (before the rsession wrapper is written) so the chosen CUDA build
# can be exported into the R session.
#
# Enable --nv only when Slurm actually GRANTED a GPU, signalled via
# CUDA_VISIBLE_DEVICES / SLURM_JOB_GPUS (set by the gres plugin). Do NOT probe
# /dev/nvidia*: a CPU job that lands on a GPU-capable node (GPU nodes are in CPU
# partitions too) sees those device files despite being granted no GPU, so
# probing them would enable --nv for a CPU session and let it grab a GPU
# allocated to another user. --nv binds only the host driver (libcuda.so).
NV_FLAG=""
TORCH_CUDA_EXPORT=""
if [ -n "${CUDA_VISIBLE_DEVICES:-}" ] || [ -n "${SLURM_JOB_GPUS:-}" ] || [ -n "${GPU_DEVICE_ORDINAL:-}" ]; then
  NV_FLAG="--nv"
  echo "GPU granted (CUDA_VISIBLE_DEVICES='${CUDA_VISIBLE_DEVICES:-}', SLURM_JOB_GPUS='${SLURM_JOB_GPUS:-}') -> enabling Singularity --nv"

  # Pick the R torch CUDA build for THIS node, rather than hardcoding one: the
  # highest torch-supported build that does not exceed the driver's max CUDA
  # (from nvidia-smi). Read live per node, so it adapts to per-node drivers and
  # future upgrades. The image ships no CUDA toolkit, so torch's auto-installer
  # would otherwise fetch the CPU build; exporting CUDA into the R session makes
  # torch::install_torch() fetch the matching GPU build (only the driver is
  # needed at runtime -- the build bundles the toolkit). The supported list is
  # config-overridable (RSTUDIO_TORCH_CUDA) so new cuXXX builds need no code edit.
  _torch_cuda_supported="<%= (rsd_conf['RSTUDIO_TORCH_CUDA'] || '12.9 12.8 12.6') %>"
  _cuda_ceiling="$(nvidia-smi 2>/dev/null | grep -oE 'CUDA Version: [0-9]+\.[0-9]+' | grep -oE '[0-9]+\.[0-9]+' | head -1)"
  if [ -n "${_cuda_ceiling}" ]; then
    for _b in ${_torch_cuda_supported}; do
      if [ "$(printf '%s\n%s\n' "${_b}" "${_cuda_ceiling}" | sort -V | tail -1)" = "${_cuda_ceiling}" ]; then
        TORCH_CUDA_EXPORT="export CUDA=\"${_b}\""
        echo "R torch -> CUDA ${_b} (node driver supports up to ${_cuda_ceiling})"
        break
      fi
    done
    [ -n "${TORCH_CUDA_EXPORT}" ] || echo "No torch CUDA build <= driver ${_cuda_ceiling}; leaving CUDA unset (torch will choose)"
  fi
else
  echo "No GPU granted to this job -> CPU-only (no --nv)"
fi
# ------------------------------------------------------------------------------

# Named session slot. Each slot gets its own XDG_DATA_HOME (RStudio session and
# workspace state), so multiple sessions run concurrently without stepping on
# each other's session registry. XDG_CACHE_HOME and XDG_CONFIG_HOME stay shared
# (renv library + preferences). Slots live under ~/work (a symlink to /data1),
# NOT $HOME proper, which is small -- so slot state does not consume the home
# quota. The slot dir persists, so a slot resumes and shows in the Session
# dropdown.
# ---- update notice (never an auto-update) --------------------------------------
# Compares the version stamped at deploy time against the repo's current VERSION.
# Strictly non-blocking: 3s timeout, every failure silent -- a GitHub outage must
# not delay or mark a launch. Surfaced in output.log here and in the R console
# banner via the rsession wrapper. Updating remains a deliberate user action:
#   curl -fsSL https://raw.githubusercontent.com/mjz1/rstudio-ood/main/install.sh | bash -s -- --app-only
UPDATE_NOTICE=""
_app_dir="<%= app_dir %>"
if [ -n "${_app_dir}" ] && [ -r "${_app_dir}/.deployed-version" ]; then
  _dep="$(awk '{print $1}' "${_app_dir}/.deployed-version" 2>/dev/null)"
  _latest="$(curl -fsS --max-time 3 https://raw.githubusercontent.com/mjz1/rstudio-ood/main/VERSION 2>/dev/null | head -1)"
  # Cache the verdict for the LAUNCH FORM. The form renders in the PUN, where a
  # network call would add latency to every launch for every user -- so the
  # compute node (which already has the answer) writes it, and the form just
  # reads a file. Cleared when current, so the notice disappears after updating.
  _cache="${HOME}/.config/rstudio_dev/update-notice"
  mkdir -p "$(dirname "${_cache}")" 2>/dev/null || true
  if [ -n "${_latest}" ] && [ -n "${_dep}" ] && [ "${_latest}" != "${_dep}" ]; then
    UPDATE_NOTICE="rstudio-ood ${_latest} is available (this app is ${_dep}). What changed: https://github.com/mjz1/rstudio-ood/blob/main/CHANGELOG.md | Update: curl -fsSL https://raw.githubusercontent.com/mjz1/rstudio-ood/main/install.sh | bash -s -- --app-only"
    echo "NOTE: ${UPDATE_NOTICE}"
    _latest_for_r="${_latest}"
    _dep_for_r="${_dep}"
    printf '%s\n%s\n' "${_latest}" "${_dep}" > "${_cache}" 2>/dev/null || true
  elif [ -n "${_latest}" ]; then
    rm -f "${_cache}" 2>/dev/null || true
  fi
fi
# --------------------------------------------------------------------------------

SESSION_SLOT="<%= slot %>"
RSTUDIO_WORK_DIR="<%= work_dir %>"
SLOT_DIR="${RSTUDIO_WORK_DIR}/.rstudio-sessions/${SESSION_SLOT}"
SHARED_CACHE="${RSTUDIO_WORK_DIR}/.cache"
mkdir -p "${SLOT_DIR}/data" "${SHARED_CACHE}"
# Stamp the slot as used NOW. The form's "last used" hint reads this; without
# the touch, the directory's mtime never moves after creation (children are only
# written deeper in), so an actively used slot reported the day it was made.
touch "${SLOT_DIR}"
echo "RStudio session slot: ${SESSION_SLOT}  (state in ${SLOT_DIR}/data; cache + renv shared)"

# OnDemand's per-session output dir (we are cd'd into it here; output.log and
# rsession.sh live in it). Captured before the `cd "${HOME}"` below -- the
# rsession file logger writes here so its logs travel with the session.
SESSION_DIR="${PWD}"

# Generate an `rsession` wrapper script
export RSESSION_WRAPPER_FILE="${PWD}/rsession.sh"
(
umask 077
sed 's/^ \{2\}//' > "${RSESSION_WRAPPER_FILE}" << EOL
  #!/usr/bin/env bash

  echo 'slurm:x:300:300::/opt/slurm/slurm:/bin/false' >> /etc/passwd
  # We fix the path and remove all the junk I had
  export PATH=/usr/lib/rstudio-server/bin/:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin:$HOME/.local/host/bin:$PATH

  # Per-slot RStudio session/workspace state lives under XDG_DATA_HOME, so
  # isolating it is what lets concurrent sessions coexist.
  export XDG_DATA_HOME="${SLOT_DIR}/data"
  # RSTUDIO_DATA_HOME overrides XDG_DATA_HOME *for RStudio specifically*, and a
  # user who exports it in their shell rc (a common trick to keep session state
  # off a quota'd \$HOME) silently defeats the whole slot mechanism: every
  # session writes to that one shared directory, concurrent sessions collide
  # again, and the abend-reset below -- which looks under the slot -- becomes a
  # no-op. Pin it to the slot so no inherited value can win. This is not
  # hypothetical: it was live on the developer's own account for the entire
  # lifetime of the slots feature, and no slot ever held any RStudio state.
  export RSTUDIO_DATA_HOME="${SLOT_DIR}/data/rstudio"
  # XDG_CACHE_HOME stays SHARED. renv stores its package library and cache under
  # R_user_dir("renv","cache") == \$XDG_CACHE_HOME/R/renv -- so a per-slot cache
  # moves every renv project's library out from under it (.libPaths breaks).
  # XDG_CONFIG_HOME is likewise left at ~/.config so preferences stay shared.
  export XDG_CACHE_HOME="${SHARED_CACHE}"

  # Session signifier: expose the slot to R, and load a site profile that shows
  # it (see the site-profile.R written below). R_PROFILE is the SITE profile, so
  # it runs before -- and does not replace -- the user's ~/.Rprofile or a
  # project's renv .Rprofile; our profile re-sources the image's own site file
  # so the CRAN snapshot etc. are preserved.
  export RSTUDIO_SESSION_SLOT="${SESSION_SLOT}"
  export RSTUDIO_UPDATE_LATEST="${_latest_for_r:-}"
  export RSTUDIO_UPDATE_DEPLOYED="${_dep_for_r:-}"
  export R_PROFILE="/tmp/site-profile.R"

  # System-default prefs (written to \$TMPDIR/xdg above; \$TMPDIR is bound to
  # /tmp). Prepended, so /etc/xdg still serves everything else.
  export XDG_CONFIG_DIRS="/tmp/xdg:/etc/xdg"

  # torch: on a GPU job, use the CUDA build matching this node's driver (chosen
  # above). Empty on CPU jobs, so this line vanishes and torch stays CPU.
  ${TORCH_CUDA_EXPORT}

  # Log all output from this script
  export RSESSION_LOG_FILE="${PWD}/rsession.log"

  exec &>>"\${RSESSION_LOG_FILE}"

  # Launch the original command
  echo "Launching rsession..."
  set -x
  exec rsession --r-libs-user "${R_LIBS_USER}" "\${@}"
EOL
)
chmod 700 "${RSESSION_WRAPPER_FILE}"

# Set working directory to home directory
cd "${HOME}"

# Output debug info
# module list

# echo old TMPDIR $TMPDIR
export TMPDIR=`mktemp -d`
# echo new TMPDIR $TMPDIR

mkdir -p $TMPDIR/{run,var-lib-rstudio-server,local-share-rstudio,usr}

# R site profile that signals which named session slot you are in: it sets the
# console prompt to "[<slot>] > " and prints a one-line banner at startup. $TMPDIR
# is bound to /tmp in the container, so R_PROFILE=/tmp/site-profile.R (set in the
# rsession wrapper) points here. As the SITE profile it runs before the user's
# ~/.Rprofile and any project renv profile, and re-sources the image's own site
# file so its settings (CRAN snapshot) are kept. The slot arrives via
# RSTUDIO_SESSION_SLOT, so this file itself is static.
cat > "${TMPDIR}/site-profile.R" <<'RPROFILE'
local({
  orig <- file.path(R.home("etc"), "Rprofile.site")
  if (file.exists(orig)) sys.source(orig, envir = globalenv())
})
local({
  slot <- Sys.getenv("RSTUDIO_SESSION_SLOT", unset = "")
  if (nzchar(slot)) {
    options(prompt = sprintf("[%s] > ", slot))
    message(sprintf("-- RStudio session slot: %s --", slot))
  }
  latest   <- Sys.getenv("RSTUDIO_UPDATE_LATEST",   unset = "")
  deployed <- Sys.getenv("RSTUDIO_UPDATE_DEPLOYED", unset = "")
  if (nzchar(latest) && nzchar(deployed)) {
    message(paste0(
      "\n",
      strrep("\u2500", 62), "\n",
      "  rstudio-ood update available:  ", deployed, " \u2192 ", latest, "\n",
      "  What changed:\n",
      "    https://github.com/mjz1/rstudio-ood/blob/main/CHANGELOG.md\n",
      "  Update (from a terminal):\n",
      "    curl -fsSL https://raw.githubusercontent.com/mjz1/rstudio-ood/main/install.sh | bash -s -- --app-only\n",
      strrep("\u2500", 62)
    ))
  }
})
RPROFILE

# RStudio Server 2026.06+ treats an unreadable /etc/rstudio/database.conf as a
# fatal error; 2025.09 tolerated it. The rstudio-server deb ships that file
# 0600 root:root, which is fine under Docker (where you are root) but unreadable
# under Singularity, where you are not. Point rserver at our own copy. Older
# RStudio accepts the same flag, so this is safe across all images.
cat > "${TMPDIR}/database.conf" <<'DBCONF'
provider=sqlite
directory=/var/lib/rstudio-server
DBCONF
chmod 600 "${TMPDIR}/database.conf"

# rocker's install_rstudio.sh sets logger-type=syslog, and there is no syslog in
# the container -- so rserver startup failures vanish silently and the only
# symptom is `wait_until_port_used` timing out. Log rserver to stderr so they
# land in this job's output.log instead.
#
# rsession must NOT log to stderr: after startup it captures its own stderr and
# forwards it into the R console, so a stderr logger prints every log record --
# e.g. the benign /proc read races from the memory-usage monitor ("Proc stat
# file ... missing value": a short-lived process exiting between enumeration
# and read) -- into the user's console, timestamps and all. (rocker's syslog
# default never touched stderr, which is why stock images seem "quiet".) Log
# rsession to a file in the session output dir instead: out of the console,
# kept for debugging, right next to output.log.
mkdir -p "${SESSION_DIR}/logs"
cat > "${TMPDIR}/logging.conf" <<LOGCONF
[*]
log-level=warn
logger-type=stderr

[rsession]
log-level=warn
logger-type=file
log-dir=${SESSION_DIR}/logs
LOGCONF

# Never IDLE-suspend the session. Suspension exists to free memory for other
# users on a shared server; here every session owns a dedicated Slurm
# allocation, so the RAM is reserved either way and hibernation buys nothing.
# What it DOES do is race renv on wake: the suspended state is restored before
# renv re-asserts the project library, packages load by name from R_LIBS_USER,
# and renv then fails to unload the stale versions ("Package 'glue' version
# 1.7.0 cannot be unloaded") -- leaving the session silently running non-renv
# package versions. End-of-job suspend (SIGTERM) is unaffected, so a slot still
# resumes across relaunches; after a RELAUNCH resume the same race can still
# appear once, and Session -> Restart R is the remedy.
# MERGED with the image's own rsession.conf, not written over it: the bind
# masks the file inside the SIF, and the image ships real settings there
# (copilot-enabled etc.) that a plain overwrite would silently disable. Read
# the image's copy out first, then append ours -- ours last, so we win ties.
singularity exec "<%= image %>" cat /etc/rstudio/rsession.conf 2>/dev/null > "${TMPDIR}/rsession.conf" || true
cat >> "${TMPDIR}/rsession.conf" <<'RSESSCONF'

# appended by rstudio-ood script.sh.erb:
session-timeout-minutes=0
RSESSCONF

# System-DEFAULT user prefs (each user's own Global Options override these, and
# their choices persist in ~/.config/rstudio as always). Two HPC-shaped
# defaults: no .RData workspace save/restore -- multi-GB workspace dumps racing
# the walltime kill helped nobody, and the reload is the other half of the renv
# resume race -- and sessions start in the large-storage work dir rather than
# the quota'd $HOME. Delivered via XDG_CONFIG_DIRS (exported in the rsession
# wrapper) because the image ships no /etc/rstudio/rstudio-prefs.json to bind
# over, and a file bind needs an existing target inside a read-only SIF.
mkdir -p "${TMPDIR}/xdg/rstudio"
cat > "${TMPDIR}/xdg/rstudio/rstudio-prefs.json" <<PREFS
{
  "save_workspace": "never",
  "load_workspace": false,
  "initial_working_directory": "${RSTUDIO_WORK_DIR}",
  "default_project_location": "${RSTUDIO_WORK_DIR}"
}
PREFS

# Clear the "session did not exit cleanly" prompt for THIS slot only. Scoped to
# the slot's own XDG_DATA_HOME (was ${HOME}/work/.rstudio, which is shared -- so
# launching one session used to reset every other running session's abend flag).
# RStudio keeps session state under $XDG_DATA_HOME/rstudio.
RSTUDIO_STATE_DIR="${RSTUDIO_STATE_DIR:-${SLOT_DIR}/data/rstudio}"
shopt -s nullglob
for state in "${RSTUDIO_STATE_DIR}"/sessions/active/*/session-persistent-state; do
  sed -i -e 's/abend="1"/abend="0"/' "${state}"
done
shopt -u nullglob

set -x
# Launch the RStudio Server
echo "Starting up rserver..."

export RSTUDIO_USER="${USER}"

# NV_FLAG and the torch CUDA build were decided earlier (before the rsession
# wrapper was written, so the CUDA choice could be exported into the R session).

# Host paths to bind, from RSTUDIO_BIND_PATHS (config) rather than a hard-coded
# /data1: the storage that holds a user's images, libraries and data is
# site-specific. Each is skipped if absent on this node, because singularity
# aborts on a bind source that does not exist -- so one config can serve nodes
# that differ, and a site without /data1 does not inherit ours.
BIND_ARGS=()
<%- unless bind_paths.empty? -%>
for _b in <%= bind_paths.map { |p| "'#{p}'" }.join(' ') %>; do
  if [ -e "${_b}" ]; then
    BIND_ARGS+=(-B "${_b}:${_b}")
  else
    echo "bind path not present on this node, skipping: ${_b}"
  fi
done
<%- end -%>

# Singularity forwards the host environment into the container, and this host
# exports SSL_CERT_FILE=/etc/pki/... and SSL_CERT_DIR=/etc/pki/... -- RHEL paths
# that do not exist inside the Ubuntu image. Anything doing TLS with OpenSSL
# then fails; Quarto (Deno) dies with "Failed to load platform certificates".
# Point them at the container's own CA bundle rather than using --cleanenv,
# which would also strip SLURM_* and the RStudio variables we rely on.
#
# --www-address is pinned to 0.0.0.0 because the OnDemand web node reaches
# this rserver ACROSS THE NETWORK. Sessions have only ever worked because
# the unset default happens to bind all interfaces -- reachability from the
# browser hung on a default Posit could move in any release, invisibly,
# because rserver would still start "healthy". The flag that decides network
# reachability does not get left to a default.
<%= singularity %> exec ${NV_FLAG} -B "$TMPDIR:/tmp" \
 -B "$TMPDIR/run:/run" \
 -B "$TMPDIR/var-lib-rstudio-server:/var/lib/rstudio-server" \
 -B "$TMPDIR/local-share-rstudio:/home/rstudio/.local/share/rstudio" \
 -B "$TMPDIR/logging.conf:/etc/rstudio/logging.conf" \
 -B "$TMPDIR/rsession.conf:/etc/rstudio/rsession.conf" \
 "${BIND_ARGS[@]}" \
 -B "${HOME}:${HOME}" \
 --env SSL_CERT_FILE=/etc/ssl/certs/ca-certificates.crt \
 --env SSL_CERT_DIR=/etc/ssl/certs \
 --env RSTUDIO_DATA_HOME="${SLOT_DIR}/data/rstudio" \
 "<%= image %>" rserver \
 --database-config-file=/tmp/database.conf \
 --server-user="${RSTUDIO_USER}" \
 --www-address=0.0.0.0 \
 --www-port="${port}" \
 --auth-none=0 \
 --auth-pam-require-password-prompt=0 \
 --auth-pam-helper-path="${RSTUDIO_AUTH}" \
 --auth-encrypt-password=0 \
 --auth-timeout-minutes=10080 \
 --rsession-path="${RSESSION_WRAPPER_FILE}"

# note, rserver in the container will start with the user space environment defined on host
# BUT, the rsession starts on limited environment, only related to R = no SLURM*, http*, ...
# so anything we want to pass to rsession needs to be set in $RSESSION_WRAPPER_FILE
